# OAuth Configuration
TOKEN_URL=https://login.mzoneweb.net/connect/token
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
OAUTH_USERNAME=your_oauth_username_here
OAUTH_PASSWORD=your_oauth_password_here
SCOPE=mz6-api.all mz_username
GRANT_TYPE=password
RESPONSE_TYPE=code id_token

# Admin Portal Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# Authentication Configuration
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Email Configuration (for PIN sending)
# Leave empty for development mode (PINs will be printed to console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=

# Server Configuration
FLASK_ENV=production
HOST=0.0.0.0
PORT=5000
DEBUG=False
